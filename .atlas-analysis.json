  "keyFeatures": [
    "Recursive directory scanning with customizable ignore rules",
    "XML output containing file tree visualization and complete file contents",
    "Flexible command-line control for directories, ignore patterns, and output options",
    "Clipboard integration with configurable size limits",
    "Safe file handling with overwrite confirmation prompts",
    "Support for .gitignore and .chettuignore files"
  ],
  "publicApiSurface": [
    "--directory / -d: Directory to scan (repeatable)",
    "--ignore-line / -l: Pattern to ignore (repeatable)",
    "--ignore-file / -f: Ignore file to use (repeatable)",
    "--reset-ignore: Discard default ignore patterns",
    "--project-name / -n: Set project name in output",
    "--output-file / -o: Output file path",
    "--output-file-replace / -R: Force overwrite existing output file",
    "--copy / -c: Copy to clipboard with max size in bytes"
  ]
}
