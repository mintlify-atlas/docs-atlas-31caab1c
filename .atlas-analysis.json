{
  "projectType": "cli-tool",
  "projectName": "Chettu",
  "projectDescription": "A command-line tool that generates XML representations of project file structures and content for LLM context and codebase analysis",
  "theme": "aspen",
  "primaryColor": "#22c55e",
  "lightColor": "#4ade80",
  "darkColor": "#16a34a",
